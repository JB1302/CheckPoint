@using CheckPoint.Models.AuditLogs
@using MongoDB.Bson
@model List<AuditLog>

@{
    ViewData["Title"] = "Bitácora";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <span class="cp-kicker">Auditoría</span>
        <h2 class="text-warning mb-1">Bitácora del sistema</h2>
        <p class="text-secondary mb-0">Consulta las acciones registradas dentro de la plataforma.</p>
    </div>
</div>

<div class="card bg-dark border-secondary shadow-sm">
    <div class="card-body">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5 text-secondary">
                No hay registros de auditoría disponibles.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Usuario</th>
                            <th>Acción</th>
                            <th>Entidad</th>
                            <th>ID entidad</th>
                            <th>Fecha</th>
                            <th>Metadata</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model)
                        {
                            <tr>
                                <td>@log.UserId</td>
                                <td>
                                    <span class="badge bg-warning text-dark">@log.Action</span>
                                </td>
                                <td>@log.EntityType</td>
                                <td>@log.EntityId</td>
                                <td>@log.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-secondary">
                                    @(log.Metadata == null ? "-" : log.Metadata.ToJson())
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>