@model ProfileViewModel

<div class="card mb-3">
    <div class="row g-0">
        <div class="col-md-4">
            @if (!string.IsNullOrEmpty(Model.Avatar))
            {
                <img src="@Model.Avatar" class="img-fluid rounded-start" alt="@Model.Username">
            }
            else
            {
                <div class="bg-secondary text-center p-5">
                    <span class="display-4">@Model.Username.Substring(0, 1).ToUpper()</span>
                </div>
            }
        </div>
        <div class="col-md-8">
            <div class="card-body">
                <h5 class="card-title">@Model.Username</h5>
                <p class="card-text">@Model.Bio</p>
                <p class="card-text"><small class="text-muted">Miembro desde @Model.JoinedAt.ToString("dd/MM/yyyy")</small></p>
                <a asp-action="Details" asp-route-id="@Model.UserId" class="btn btn-primary">Ver Perfil</a>
            </div>
        </div>
    </div>
</div>