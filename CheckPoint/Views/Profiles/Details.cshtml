@model ProfileViewModel
@{
    ViewData["Title"] = $"Perfil de {Model.Username}";
}

<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body text-center">
                @if (!string.IsNullOrEmpty(Model.Avatar))
                {
                    <img src="@Model.Avatar" class="rounded-circle img-fluid" style="width: 150px; height: 150px; object-fit: cover;" />
                }
                else
                {
                    <div class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center" style="width: 150px; height: 150px;">
                        <span class="display-1 text-white">@Model.Username.Substring(0, 1).ToUpper()</span>
                    </div>
                }
                <h3 class="mt-3">@Model.Username</h3>
                <p class="text-muted">Miembro desde @Model.JoinedAt.ToString("MMMM yyyy")</p>
                @if (User.Identity.Name == Model.Username)
                {
                    <a asp-action="Edit" class="btn btn-primary">Editar Perfil</a>
                }
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-header">
                <h5>Información Personal</h5>
            </div>
            <div class="card-body">
                <p><strong>Bio:</strong> @Model.Bio</p>
                <p><strong>Ubicación:</strong> @Model.Location</p>
                <p><strong>Sitio Web:</strong> <a href="@Model.Website" target="_blank">@Model.Website</a></p>
            </div>
        </div>
        
        <div class="card">
            <div class="card-header">
                <h5>Juegos Favoritos</h5>
            </div>
            <div class="card-body">
                @await Html.PartialAsync("_FavoriteGamesSelector", Model.FavoriteGames)
            </div>
        </div>
    </div>
</div>