@{
    ViewData["Title"] = "Acerca de";
}

<div class="cp-hero mb-5 text-center">
    <span class="cp-kicker">Sobre la plataforma</span>
    <h1 class="display-5 fw-bold text-warning">Acerca de CheckPoint</h1>
    <p class="lead text-light mx-auto" style="max-width: 760px;">
        CheckPoint integra gestión de eventos, interacción social y comunidad gamer en una sola plataforma.
    </p>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card h-100 bg-dark border-secondary">
            <div class="card-body">
                <h5 class="text-warning">Eventos</h5>
                <p class="text-secondary mb-0">
                    Crea, publica y administra competencias de forma estructurada.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 bg-dark border-secondary">
            <div class="card-body">
                <h5 class="text-warning">Comunidad</h5>
                <p class="text-secondary mb-0">
                    Interactúa mediante publicaciones, comentarios y notificaciones.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 bg-dark border-secondary">
            <div class="card-body">
                <h5 class="text-warning">Escalabilidad</h5>
                <p class="text-secondary mb-0">
                    Usa MongoDB para manejar datos flexibles y crecer con la comunidad.
                </p>
            </div>
        </div>
    </div>
</div>