@model CheckPoint.Models.Events.Events

<div class="card h-100">
    <div class="card-header">
        <h5 class="card-title">@Model.Title</h5>
    </div>
    <div class="card-body">
        <p class="card-text">@(string.IsNullOrWhiteSpace(Model.Description) ? "" : Model.Description.Length > 100 ? Model.Description.Substring(0, 100) + "..." : Model.Description)</p>
        <p><strong>Juego:</strong> @Model.GameId</p>
        <p><strong>Fecha:</strong> @Model.StartDate.ToString("dd/MM/yyyy HH:mm")</p>
        <p><strong>Ubicación:</strong> @Model.Location</p>
        <p><strong>Cupo máximo:</strong> @Model.MaxParticipants</p>
    </div>
    <div class="card-footer">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-primary">Ver Detalles</a>
        @if (User.Identity.IsAuthenticated)
        {
            @await Html.PartialAsync("_JoinButton", Model)
        }
    </div>
</div>
