@model CheckPoint.ViewModels.EventFiltersViewModel

<form asp-action="Index" method="get" class="mb-4">
    <div class="row">
        <div class="col-md-3">
            <input type="text" name="search" class="form-control" placeholder="Buscar eventos..." value="@Model.Search" />
        </div>
        <div class="col-md-2">
            <select name="gameId" class="form-control">
                <option value="">Todos los juegos</option>
                @foreach (var game in Model.Games)
                {
                    <option value="@game.Id" selected="@(Model.GameId == game.Id)">@game.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <input type="date" name="fromDate" class="form-control" value="@Model.FromDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-2">
            <input type="date" name="toDate" class="form-control" value="@Model.ToDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary">Filtrar</button>
            <a asp-action="Index" class="btn btn-secondary">Limpiar</a>
        </div>
    </div>
</form>
