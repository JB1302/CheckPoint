@model CheckPoint.ViewModels.CreateEventViewModel

<div class="mb-3">
    <label asp-for="Title" class="form-label"></label>
    <input asp-for="Title" class="form-control" required />
    <span asp-validation-for="Title" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="Description" class="form-label"></label>
    <textarea asp-for="Description" class="form-control" rows="5" required></textarea>
</div>

<div class="mb-3">
    <label asp-for="GameId" class="form-label"></label>
    <select asp-for="GameId" asp-items="Model.GameOptions" class="form-control" required>
        <option value="">Selecciona un juego</option>
    </select>
</div>

<div class="mb-3">
    <label asp-for="StartDate" class="form-label"></label>
    <input asp-for="StartDate" type="datetime-local" class="form-control" required />
</div>

<div class="mb-3">
    <label asp-for="EventType" class="form-label"></label>
    <input asp-for="EventType" class="form-control" />
</div>

<div class="mb-3">
    <label asp-for="MaxParticipants" class="form-label"></label>
    <input asp-for="MaxParticipants" type="number" class="form-control" min="1" required />
</div>
