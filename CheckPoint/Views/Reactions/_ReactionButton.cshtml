@model PostViewModel

<div class="btn-group" role="group">
    <button type="button" class="btn btn-sm btn-outline-primary" onclick="react(@Model.Id, 'Like')">
        👍 Like (@Model.Reactions.Count(r => r.Type == "Like"))
    </button>
    <button type="button" class="btn btn-sm btn-outline-primary" onclick="react(@Model.Id, 'Love')">
        ❤️ Love (@Model.Reactions.Count(r => r.Type == "Love"))
    </button>
    <button type="button" class="btn btn-sm btn-outline-primary" onclick="react(@Model.Id, 'Funny')">
        😂 Funny (@Model.Reactions.Count(r => r.Type == "Funny"))
    </button>
</div>

<script>
    function react(postId, type) {
        fetch(`/api/reactions`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ postId: postId, type: type })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            }
        });
    }
</script>