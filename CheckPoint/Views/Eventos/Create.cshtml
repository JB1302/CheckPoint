@model CheckPoint.ViewModels.CrearEventoViewModel
@{
    ViewData["Title"] = "Crear Evento";
}

<h2 class="text-warning mb-4">Crear nuevo evento</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

    <div class="row g-3">
        <div class="col-md-8">
            <label asp-for="Title" class="form-label text-light"></label>
            <input asp-for="Title" class="form-control bg-dark text-light border-secondary" />
            <span asp-validation-for="Title" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="GameId" class="form-label text-light"></label>
            <select asp-for="GameId" asp-items="Model.GameOptions" class="form-select bg-dark text-light border-secondary">
                <option value="">-- Selecciona --</option>
            </select>
            <span asp-validation-for="GameId" class="text-danger small"></span>
        </div>
        <div class="col-12">
            <label asp-for="Description" class="form-label text-light"></label>
            <textarea asp-for="Description" rows="4" class="form-control bg-dark text-light border-secondary"></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Type" class="form-label text-light"></label>
            <select asp-for="Type" class="form-select bg-dark text-light border-secondary" id="eventType">
                <option value="Online">Online</option>
                <option value="InPerson">Presencial</option>
                <option value="Hybrid">Híbrido</option>
            </select>
        </div>
        <div class="col-md-4">
            <label asp-for="Format" class="form-label text-light"></label>
            <input asp-for="Format" class="form-control bg-dark text-light border-secondary" placeholder="Ej. Single Elimination" />
        </div>
        <div class="col-md-4">
            <label asp-for="MaxParticipants" class="form-label text-light"></label>
            <input asp-for="MaxParticipants" type="number" class="form-control bg-dark text-light border-secondary" />
            <span asp-validation-for="MaxParticipants" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="StartDate" class="form-label text-light"></label>
            <input asp-for="StartDate" type="datetime-local" class="form-control bg-dark text-light border-secondary" />
            <span asp-validation-for="StartDate" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="EndDate" class="form-label text-light"></label>
            <input asp-for="EndDate" type="datetime-local" class="form-control bg-dark text-light border-secondary" />
        </div>
        <div class="col-md-4">
            <label asp-for="RegistrationDeadline" class="form-label text-light"></label>
            <input asp-for="RegistrationDeadline" type="datetime-local" class="form-control bg-dark text-light border-secondary" />
        </div>
        <div class="col-md-6">
            <label asp-for="PrizePool" class="form-label text-light"></label>
            <input asp-for="PrizePool" class="form-control bg-dark text-light border-secondary" placeholder="Ej. $500 USD" />
        </div>
        <div class="col-md-6">
            <label asp-for="StreamUrl" class="form-label text-light"></label>
            <input asp-for="StreamUrl" class="form-control bg-dark text-light border-secondary" placeholder="https://twitch.tv/..." />
            <span asp-validation-for="StreamUrl" class="text-danger small"></span>
        </div>
        <div class="col-12">
            <label asp-for="TagsRaw" class="form-label text-light"></label>
            <input asp-for="TagsRaw" class="form-control bg-dark text-light border-secondary" placeholder="fps, competitivo, online" />
        </div>

        <!-- Location fields (shown for InPerson / Hybrid) -->
        <div id="locationFields" class="col-12 d-none">
            <hr class="border-secondary">
            <h6 class="text-warning">Información del lugar</h6>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="VenueName" class="form-label text-light"></label>
                    <input asp-for="VenueName" class="form-control bg-dark text-light border-secondary" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Address" class="form-label text-light"></label>
                    <input asp-for="Address" class="form-control bg-dark text-light border-secondary" />
                </div>
                <div class="col-md-6">
                    <label asp-for="City" class="form-label text-light"></label>
                    <input asp-for="City" class="form-control bg-dark text-light border-secondary" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Country" class="form-label text-light"></label>
                    <input asp-for="Country" class="form-control bg-dark text-light border-secondary" />
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-warning px-5">Crear evento</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const typeSelect = document.getElementById('eventType');
        const locationFields = document.getElementById('locationFields');
        function toggleLocation() {
            locationFields.classList.toggle('d-none', typeSelect.value === 'Online');
        }
        typeSelect.addEventListener('change', toggleLocation);
        toggleLocation();
    </script>
}

