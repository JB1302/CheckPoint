@using CheckPoint.ViewModels
@using CheckPoint.Models
@model DetalleEventoViewModel
@{
    ViewData["Title"] = Model.Evento.Title;
    var ev = Model.Evento;
    var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<div class="row g-4">
    <!-- Seccion principal -->
    <div class="col-lg-8">
        <img src="@ev.ImageUrl" class="img-fluid rounded mb-3 w-100" style="max-height:300px;object-fit:cover" onerror="this.src='/img/default-event.png'">

        <div class="d-flex gap-2 mb-3">
            <span class="badge bg-warning text-dark fs-6">@ev.Type</span>
            <span class="badge bg-secondary fs-6">@ev.Status</span>
            @foreach (var tag in ev.Tags)
            {
                <span class="badge bg-dark border border-secondary">#@tag</span>
            }
        </div>

        <h2 class="text-warning">@ev.Title</h2>
        <p class="text-secondary">@ev.Description</p>

        @if (Model.Rules != null && !string.IsNullOrWhiteSpace(Model.Rules.AdditionalRules))
        {
            <h5 class="text-light mt-4">Reglas del evento</h5>
            <p class="text-secondary">@Model.Rules.AdditionalRules</p>
        }

        <!-- Publicaciones y anuncios -->
        <hr class="border-secondary mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="text-light mb-0">Publicaciones</h5>
            @if (Model.IsOrganizer || User.IsInRole("Admin"))
            {
                <a asp-controller="Publicaciones" asp-action="Create" asp-route-eventId="@ev.Id" class="btn btn-sm btn-outline-warning">+ Nueva publicación</a>
            }
        </div>

        @if (!Model.Posts.Any())
        {
            <p class="text-secondary small">No hay publicaciones aún.</p>
        }
        else
        {
            @foreach (var post in Model.Posts)
            {
                <div class="card bg-dark border-secondary mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <h6 class="text-warning">@post.Title <span class="badge bg-secondary ms-1">@post.Type</span></h6>
                            <small class="text-secondary">@post.CreatedAt.ToString("dd MMM")</small>
                        </div>
                        <p class="text-light mb-2">@post.Content</p>
                        <!-- Formulario de comentario -->
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <form asp-controller="Publicaciones" asp-action="AddComment" method="post" class="mt-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="PostId" value="@post.Id" />
                                <input type="hidden" name="EventId" value="@ev.Id" />
                                <div class="input-group input-group-sm">
                                    <input type="text" name="Content" class="form-control bg-dark text-light border-secondary" placeholder="Comentar..." maxlength="500" required />
                                    <button type="submit" class="btn btn-outline-warning">Enviar</button>
                                </div>
                            </form>
                        }
                    </div>
                </div>
            }
        }
    </div>

    <!-- Barra lateral -->
    <div class="col-lg-4">
        <div class="card bg-dark border-secondary mb-3">
            <div class="card-body">
                <h6 class="text-warning">Detalles</h6>
                <ul class="list-unstyled text-secondary small">
                    <li><strong class="text-light">Juego:</strong> @(Model.Juego?.Name ?? "N/D")</li>
                    <li><strong class="text-light">Formato:</strong> @(string.IsNullOrEmpty(ev.Format) ? "N/D" : ev.Format)</li>
                    <li><strong class="text-light">Inicio:</strong> @ev.StartDate.ToString("dd/MM/yyyy HH:mm")</li>
                    <li><strong class="text-light">Fin:</strong> @ev.EndDate.ToString("dd/MM/yyyy HH:mm")</li>
                    <li><strong class="text-light">Inscripciones hasta:</strong> @ev.RegistrationDeadline.ToString("dd/MM/yyyy")</li>
                    <li><strong class="text-light">Cupos:</strong> @ev.CurrentParticipants / @ev.MaxParticipants</li>
                    @if (!string.IsNullOrEmpty(ev.PrizePool))
                    {
                        <li><strong class="text-light">Premio:</strong> @ev.PrizePool</li>
                    }
                    @if (!string.IsNullOrEmpty(ev.StreamUrl))
                    {
                        <li><strong class="text-light">Stream:</strong> <a href="@ev.StreamUrl" target="_blank" class="text-warning">Ver stream</a></li>
                    }
                </ul>

                @if (ev.Location != null && !string.IsNullOrEmpty(ev.Location.VenueName))
                {
                    <h6 class="text-warning mt-3">Lugar</h6>
                    <p class="text-secondary small mb-0">@ev.Location.VenueName<br />@ev.Location.Address<br />@ev.Location.City, @ev.Location.Country</p>
                }

                <!-- Acciones de inscripcion -->
                <div class="mt-3">
                    @if (Model.IsRegistered)
                    {
                        <div class="alert alert-success py-2 small mb-2">Inscrito</div>
                        <form asp-controller="Inscripciones" asp-action="Cancel" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="eventId" value="@ev.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">Cancelar inscripción</button>
                        </form>
                    }
                    else if (Model.CanRegister)
                    {
                        <form asp-controller="Inscripciones" asp-action="Join" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="eventId" value="@ev.Id" />
                            <button type="submit" class="btn btn-warning w-100">Inscribirme</button>
                        </form>
                    }
                    else if (!User.Identity?.IsAuthenticated ?? true)
                    {
                        <a asp-controller="Cuenta" asp-action="Login" class="btn btn-outline-warning w-100">Inicia sesión para inscribirte</a>
                    }
                </div>

                <!-- Acciones del organizador -->
                @if (Model.IsOrganizer || User.IsInRole("Admin"))
                {
                    <hr class="border-secondary">
                    <a asp-controller="Eventos" asp-action="Edit" asp-route-id="@ev.Id" class="btn btn-sm btn-outline-light w-100 mb-2">Editar evento</a>
                    @if (ev.Status != "Cancelled")
                    {
                        <form asp-controller="Eventos" asp-action="Cancel" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@ev.Id" />
                            <button type="submit" class="btn btn-sm btn-danger w-100"
                                    onclick="return confirm('¿Cancelar este evento?')">Cancelar evento</button>
                        </form>
                    }
                }
            </div>
        </div>

        <!-- Participantes -->
        <div class="card bg-dark border-secondary">
            <div class="card-body">
                <h6 class="text-warning">Participantes (@Model.Registrations.Count(r => r.Status == "Confirmed"))</h6>
                @if (!Model.Registrations.Any(r => r.Status == "Confirmed"))
                {
                    <p class="text-secondary small mb-0">Nadie inscrito aún.</p>
                }
                else
                {
                    <ul class="list-unstyled text-secondary small mb-0">
                        @foreach (var r in Model.Registrations.Where(r => r.Status == "Confirmed").Take(10))
                        {
                            <li>ID: <code>@r.UserId[..8]...</code></li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>


