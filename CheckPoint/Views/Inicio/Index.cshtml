@using CheckPoint.Models
@model List<Evento>
@{
    ViewData["Title"] = "CheckPoint";
    var games = ViewBag.Games as List<Juego> ?? new();
}

<!-- Encabezado principal -->
<div class="cp-hero mb-4 text-center">
    <span class="cp-kicker">Plataforma competitiva</span>
    <h1 class="display-5 fw-bold text-warning">CheckPoint</h1>
    <p class="lead text-light">Centraliza tus torneos, sube en el ranking y construye reputacion real en tu comunidad.</p>
    <a asp-controller="Eventos" asp-action="Index" class="btn btn-warning btn-lg px-5">Explorar eventos</a>
    @if (!User.Identity?.IsAuthenticated ?? true)
    {
        <a asp-controller="Cuenta" asp-action="Register" class="btn btn-outline-warning btn-lg px-5 ms-2">Crear cuenta</a>
    }

    <div class="cp-stat-strip text-start">
        <div class="cp-stat">
            <strong>@Model.Count</strong>
            <span>Eventos activos en portada</span>
        </div>
        <div class="cp-stat">
            <strong>@games.Count</strong>
            <span>Juegos en catalogo</span>
        </div>
        <div class="cp-stat">
            <strong>24/7</strong>
            <span>Comunidad y competencia</span>
        </div>
    </div>
</div>

<!-- Proximos eventos -->
<h4 class="text-warning mb-3">Próximos Eventos</h4>

@if (!Model.Any())
{
    <div class="text-center text-secondary py-5">
        <p>No hay eventos disponibles aún. ¡Sé el primero en crear uno!</p>
        @if (User.IsInRole("Organizer") || User.IsInRole("Admin"))
        {
            <a asp-controller="Eventos" asp-action="Create" class="btn btn-warning">Crear Evento</a>
        }
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var ev in Model.Take(9))
        {
            <div class="col">
                <div class="card h-100 bg-dark border-secondary">
                    <img src="@ev.ImageUrl" class="card-img-top" alt="@ev.Title" style="height:160px;object-fit:cover" onerror="this.src='/img/default-event.png'">
                    <div class="card-body">
                        <span class="badge bg-warning text-dark mb-1">@ev.Type</span>
                        <h5 class="card-title text-light">@ev.Title</h5>
                        <p class="card-text text-secondary small">@ev.Description.Substring(0, Math.Min(100, ev.Description.Length))@(ev.Description.Length > 100 ? "..." : "")</p>
                    </div>
                    <div class="card-footer d-flex justify-content-between align-items-center">
                        <small class="text-secondary">@ev.StartDate.ToString("dd MMM yyyy")</small>
                        <small class="text-secondary">@ev.CurrentParticipants / @ev.MaxParticipants</small>
                        <a asp-controller="Eventos" asp-action="Details" asp-route-id="@ev.Id" class="btn btn-sm btn-outline-warning">Ver</a>
                    </div>
                </div>
            </div>
        }
    </div>
}


