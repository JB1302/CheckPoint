@model CheckPoint.Models.Games.Game
@{
    ViewData["Title"] = Model.Name;
}

<div class="row">
    <div class="col-md-4">
        @if (!string.IsNullOrEmpty(Model.CoverImage))
        {
            <img src="@Model.CoverImage" class="img-fluid rounded" alt="@Model.Name">
        }
    </div>
    <div class="col-md-8">
        <h1>@Model.Name</h1>
        <p><strong>Género:</strong> @Model.Genre</p>
        <p><strong>Plataforma:</strong> @Model.Platform</p>
        <p><strong>Desarrollador:</strong> @Model.Developer</p>
        <p><strong>Fecha Lanzamiento:</strong> @Model.ReleaseDate.ToString("dd/MM/yyyy")</p>
        <h3>Descripción</h3>
        <p>@Model.Description</p>
        
        <div class="mt-3">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
            <a asp-action="Index" class="btn btn-secondary">Volver</a>
        </div>
    </div>
</div>
