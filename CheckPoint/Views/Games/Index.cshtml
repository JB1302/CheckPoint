@using CheckPoint.Models.Games
@model List<Game>

@{
    ViewData["Title"] = "Juegos";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <span class="cp-kicker">Catálogo</span>
        <h2 class="text-warning mb-1">Juegos</h2>
        <p class="text-secondary mb-0">Administra y consulta el catálogo de juegos disponibles.</p>
    </div>

    <a asp-controller="Games" asp-action="Create" class="btn btn-warning">
        Agregar juego
    </a>
</div>

<div class="card bg-dark border-secondary shadow-sm">
    <div class="card-body">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5 text-secondary">
                No hay juegos registrados.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Género</th>
                            <th>Plataformas</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var game in Model)
                        {
                            <tr>
                                <td>@game.Name</td>
                                <td>@game.Genre</td>
                                <td>
                                    @if (game.Platforms != null && game.Platforms.Any())
                                    {
                                        @string.Join(", ", game.Platforms)
                                    }
                                    else
                                    {
                                        <span class="text-secondary">-</span>
                                    }
                                </td>
                                <td>
                                    @if (game.IsActive)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactivo</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-controller="Games" asp-action="Details" asp-route-id="@game.Id" class="btn btn-sm btn-outline-warning">
                                        Ver
                                    </a>
                                    <a asp-controller="Games" asp-action="Edit" asp-route-id="@game.Id" class="btn btn-sm btn-outline-light">
                                        Editar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>