@{
    ViewData["Title"] = "Juegos";
    var canManageGames = User.IsInRole("Admin");
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <span class="cp-kicker">Catálogo</span>
        <h2 class="text-warning mb-1">Juegos</h2>
        <p class="text-secondary mb-0">Administra y consulta el catálogo de juegos disponibles.</p>
    </div>
    @if (canManageGames)
    {
        <button class="btn btn-warning" onclick="abrirModalCrear()">Agregar juego</button>
    }
</div>

<div class="card bg-dark border-secondary shadow-sm">
    <div class="card-body">
        <div id="cargando" class="text-center py-5 text-secondary">Cargando juegos...</div>
        <div id="sinJuegos" class="text-center py-5 text-secondary d-none">No hay juegos registrados.</div>

        <div class="table-responsive d-none" id="contenedorTabla">
            <table class="table table-dark table-hover align-middle">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Género</th>
                        <th>Plataformas</th>
                        <th>Estado</th>
                        @if (canManageGames)
                        {
                            <th class="text-end">Acciones</th>
                        }
                    </tr>
                </thead>
                <tbody id="tablaJuegos"></tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Crear / Editar -->
<div class="modal fade" id="modalJuego" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark border-secondary text-light">
            <div class="modal-header border-secondary">
                <h5 class="modal-title" id="modalTitulo">Agregar juego</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="juegoId" />

                <div class="mb-3">
                    <label class="form-label">Nombre</label>
                    <input type="text" id="juegoNombre" class="form-control" placeholder="Ej: Diablo IV" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Género</label>
                    <input type="text" id="juegoGenero" class="form-control" placeholder="Ej: Action RPG" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Plataformas <span class="text-secondary small">(separadas por coma)</span></label>
                    <input type="text" id="juegoPlataformas" class="form-control" placeholder="Ej: PC, PS5, Xbox Series X" />
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="juegoActivo" checked />
                    <label class="form-check-label">Activo</label>
                </div>
                <div id="errorJuego" class="text-danger mt-2 d-none"></div>
            </div>
            <div class="modal-footer border-secondary">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button class="btn btn-warning" onclick="guardarJuego()">Guardar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Confirmar Eliminar -->
<div class="modal fade" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content bg-dark border-danger text-light">
            <div class="modal-header border-danger">
                <h5 class="modal-title">Eliminar juego</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Estás segura de que deseas eliminar <strong id="nombreEliminar"></strong>?</p>
                <input type="hidden" id="idEliminar" />
            </div>
            <div class="modal-footer border-danger">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button class="btn btn-danger" onclick="confirmarEliminar()">Eliminar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const modalJuego   = new bootstrap.Modal(document.getElementById('modalJuego'));
    const modalEliminar = new bootstrap.Modal(document.getElementById('modalEliminar'));

    async function cargarJuegos() {
        const res = await fetch('/api/juegos');
        const juegos = await res.json();

        document.getElementById('cargando').classList.add('d-none');

        if (!juegos.length) {
            document.getElementById('sinJuegos').classList.remove('d-none');
            return;
        }

        document.getElementById('contenedorTabla').classList.remove('d-none');
        const tbody = document.getElementById('tablaJuegos');
        tbody.innerHTML = '';

        juegos.forEach(j => {
            const estadoBadge = j.isActive
                ? '<span class="badge bg-success">Activo</span>'
                : '<span class="badge bg-secondary">Inactivo</span>';

            const plataformas = j.platforms?.length
                ? j.platforms.join(', ')
                : '<span class="text-secondary">-</span>';

            tbody.innerHTML += `
                <tr>
                    <td>${j.name}</td>
                    <td>${j.genre}</td>
                    <td>${plataformas}</td>
                    <td>${estadoBadge}</td>
                    ${canManageGames ? `<td class="text-end">
                        <button class="btn btn-sm btn-outline-warning me-1" onclick="abrirModalEditar('${j.id}','${escapar(j.name)}','${escapar(j.genre)}','${escapar((j.platforms||[]).join(', '))}',${j.isActive})">
                            Editar
                        </button>
                        <button class="btn btn-sm btn-outline-danger" onclick="abrirModalEliminar('${j.id}','${escapar(j.name)}')">
                            Eliminar
                        </button>
                    </td>` : ''}
                </tr>`;
        });
    }

    function escapar(str) {
        return (str || '').replace(/'/g, "\\'");
    }

    function abrirModalCrear() {
        document.getElementById('modalTitulo').textContent = 'Agregar juego';
        document.getElementById('juegoId').value = '';
        document.getElementById('juegoNombre').value = '';
        document.getElementById('juegoGenero').value = '';
        document.getElementById('juegoPlataformas').value = '';
        document.getElementById('juegoActivo').checked = true;
        document.getElementById('errorJuego').classList.add('d-none');
        modalJuego.show();
    }

    function abrirModalEditar(id, nombre, genero, plataformas, activo) {
        document.getElementById('modalTitulo').textContent = 'Editar juego';
        document.getElementById('juegoId').value = id;
        document.getElementById('juegoNombre').value = nombre;
        document.getElementById('juegoGenero').value = genero;
        document.getElementById('juegoPlataformas').value = plataformas;
        document.getElementById('juegoActivo').checked = activo;
        document.getElementById('errorJuego').classList.add('d-none');
        modalJuego.show();
    }

    async function guardarJuego() {
        const id          = document.getElementById('juegoId').value;
        const nombre      = document.getElementById('juegoNombre').value.trim();
        const genero      = document.getElementById('juegoGenero').value.trim();
        const plataformas = document.getElementById('juegoPlataformas').value
                              .split(',').map(p => p.trim()).filter(p => p);
        const activo      = document.getElementById('juegoActivo').checked;
        const errDiv      = document.getElementById('errorJuego');

        if (!nombre || !genero) {
            errDiv.textContent = 'Nombre y género son obligatorios.';
            errDiv.classList.remove('d-none');
            return;
        }

        const body    = { name: nombre, genre: genero, platforms: plataformas, isActive: activo };
        const url     = id ? `/api/juegos/${id}` : '/api/juegos';
        const method  = id ? 'PUT' : 'POST';

        const res = await fetch(url, {
            method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });

        if (!res.ok) {
            const data = await res.json();
            errDiv.textContent = data.mensaje || 'Error al guardar.';
            errDiv.classList.remove('d-none');
            return;
        }

        modalJuego.hide();
        cargarJuegos();
    }

    function abrirModalEliminar(id, nombre) {
        document.getElementById('idEliminar').value = id;
        document.getElementById('nombreEliminar').textContent = nombre;
        modalEliminar.show();
    }

    async function confirmarEliminar() {
        const id = document.getElementById('idEliminar').value;
        await fetch(`/api/juegos/${id}`, { method: 'DELETE' });
        modalEliminar.hide();
        cargarJuegos();
    }

    const canManageGames = @(canManageGames ? "true" : "false");
    cargarJuegos();
</script>
}
