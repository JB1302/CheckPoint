@{
    var title = ViewData["Title"] as string ?? "CheckPoint";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - CheckPoint</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
            body {
                background-color: #0f1115;
                color: #e9ecef;
                margin: 0;
            }

            .cp-shell {
                min-height: 100vh;
            }

            .cp-sidebar {
                min-height: 100vh;
                background: #151922;
                border-right: 1px solid #2a2f3a;
            }

            .cp-content {
                min-height: 100vh;
                background: #0f1115;
            }

            .cp-brand {
                color: #ffc107;
                font-weight: 700;
                text-decoration: none;
                font-size: 1.4rem;
            }

            .cp-card {
                background: #171b24;
                border: 1px solid #2b3240;
                border-radius: 14px;
            }

            .cp-kicker {
                display: inline-block;
                padding: .35rem .75rem;
                border-radius: 999px;
                background: rgba(255,193,7,.12);
                color: #ffc107;
                font-size: .85rem;
                margin-bottom: 1rem;
            }

            .cp-stat-strip {
                margin-top: 2rem;
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
                gap: 1rem;
            }

            .cp-stat {
                background: #171b24;
                border: 1px solid #2b3240;
                border-radius: 12px;
                padding: 1rem;
            }

                .cp-stat strong {
                    display: block;
                    color: #ffc107;
                    font-size: 1.3rem;
                }

                .cp-stat span {
                    color: #adb5bd;
                    font-size: .9rem;
                }

            .cp-sidebar .nav-link {
                color: #ced4da;
                border-radius: 10px;
                margin-bottom: .25rem;
                text-decoration: none;
                display: block;
                padding: .6rem .8rem;
            }

                .cp-sidebar .nav-link:hover {
                    background: #212734;
                    color: #ffc107;
                }

            .cp-main-container {
                max-width: 1400px;
                margin: 0 auto;
            }

            .table {
                color: #e9ecef;
            }

            .form-control, .form-select {
                background-color: #0f1115;
                color: #e9ecef;
                border: 1px solid #343a40;
            }

                .form-control:focus, .form-select:focus {
                    background-color: #0f1115;
                    color: #e9ecef;
                    border-color: #ffc107;
                    box-shadow: 0 0 0 .2rem rgba(255,193,7,.15);
                }
    </style>
</head>
<body>
    <div class="container-fluid cp-shell">
        <div class="row g-0">
            <aside class="col-md-3 col-lg-2 cp-sidebar p-3">
                @await Html.PartialAsync("_SidebarAdmin")
            </aside>

            <div class="col-md-9 col-lg-10 cp-content">
                @await Html.PartialAsync("_TopNavbar")

                <main class="p-4 cp-main-container">
                    @await Html.PartialAsync("_StatusMessage")
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await Html.PartialAsync("_ValidationScriptsPartial")
    @RenderSection("Scripts", required: false)
</body>
</html>