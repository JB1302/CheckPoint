@model CheckPoint.Models.Posts.Post

<div class="card mb-3 bg-dark text-white border-secondary">
    <div class="card-header text-white">
        <strong class="text-white">@Model.AuthorId</strong>
        <small class="text-white float-end">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
    </div>
    <div class="card-body text-white">
        <p class="card-text text-white">@Model.Content</p>
        
        <div class="mt-2">
            @await Html.PartialAsync("~/Views/Reactions/_ReactionButton.cshtml", Model)
            @await Html.PartialAsync("~/Views/Reactions/_ReactionSummary.cshtml", Model)
        </div>
        
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <button class="btn btn-sm btn-link text-white" onclick="toggleComments('@Model.Id')">Comentarios</button>
            <div id="comments-@Model.Id" style="display:none;" class="mt-3 text-white">
                @await Html.PartialAsync("~/Views/Comments/_CommentList.cshtml", Model.Comments)
                @await Html.PartialAsync("~/Views/Comments/_CommentForm.cshtml", Model.Id)
            </div>
        }
        
        @if (User.Identity?.Name == Model.AuthorId || User.IsInRole("Admin"))
        {
            <div class="float-end">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-warning">Editar</a>
            </div>
        }
    </div>
</div>

<script>
    function toggleComments(postId) {
        var commentsDiv = document.getElementById('comments-' + postId);
        if (commentsDiv.style.display === 'none') {
            commentsDiv.style.display = 'block';
        } else {
            commentsDiv.style.display = 'none';
        }
    }
</script>