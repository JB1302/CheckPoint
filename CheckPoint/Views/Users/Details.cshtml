@model CheckPoint.Models.Users.User
@{
    ViewData["Title"] = $"Perfil de {Model.Username}";
}

<div class="card bg-dark text-white">
    <div class="card-header text-white">
        <h2 class="text-white">@Model.Username</h2>
    </div>
    <div class="card-body text-white">
        <dl class="row text-white">
            <dt class="col-sm-3 text-white">Email:</dt>
            <dd class="col-sm-9 text-white">@Model.Email</dd>

            <dt class="col-sm-3 text-white">Fecha Registro:</dt>
            <dd class="col-sm-9 text-white">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3 text-white">Estado:</dt>
            <dd class="col-sm-9 text-white">@await Html.PartialAsync("_UserStatusBadge", Model.IsActive ? "Active" : "Suspended")</dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
        <a asp-action="Index" class="btn btn-secondary">Volver</a>
    </div>
</div>