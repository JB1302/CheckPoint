@model CheckPoint.Models.Users.User

<div class="mb-3">
    <label asp-for="Username" class="form-label text-white"></label>
    <input asp-for="Username" class="form-control text-white bg-dark border-secondary" />
    <span asp-validation-for="Username" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="Email" class="form-label text-white"></label>
    <input asp-for="Email" type="email" class="form-control text-white bg-dark border-secondary" />
    <span asp-validation-for="Email" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="PasswordHash" class="form-label text-white">Contraseña</label>
    <input asp-for="PasswordHash" type="password" class="form-control text-white bg-dark border-secondary" />
    <span asp-validation-for="PasswordHash" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="Role" class="form-label text-white"></label>
    <select asp-for="Role" class="form-control text-white bg-dark border-secondary">
        <option value="">Seleccione un rol</option>
        <option value="Admin">Admin</option>
        <option value="User">User</option>
        <option value="Moderator">Moderator</option>
    </select>
    <span asp-validation-for="Role" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="IsActive" class="form-label text-white"></label>
    <select asp-for="IsActive" class="form-control text-white bg-dark border-secondary">
        <option value="true">Activo</option>
        <option value="false">Suspendido</option>
    </select>
</div>