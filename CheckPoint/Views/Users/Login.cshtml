@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card bg-dark border-secondary shadow-sm">
            <div class="card-body p-4">
                <h2 class="text-warning mb-4">Iniciar sesión</h2>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label text-light">Correo electrónico</label>
                        <input name="email" type="email" class="form-control bg-black text-light border-secondary" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-light">Contraseña</label>
                        <input name="password" type="password" class="form-control bg-black text-light border-secondary" required />
                    </div>

                    <button type="submit" class="btn btn-warning w-100">Entrar</button>
                </form>
            </div>
        </div>
    </div>
</div>