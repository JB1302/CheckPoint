@model CheckPoint.Models.Users.User
@{
    ViewData["Title"] = "Editar Usuario";
}

<h1 class="text-white">Editar Usuario: @Model.Username</h1>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    @await Html.PartialAsync("_UserForm", Model)

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Guardar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        <a asp-controller="Users" asp-action="Index" class="btn btn-outline-light">Volver a Usuarios</a>
    </div>
</form>