@model CheckPoint.ViewModels.RegistroViewModel

@{
    ViewData["Title"] = "Registrarse";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card bg-dark border-secondary shadow-sm">
            <div class="card-body p-4">
                <h2 class="text-warning mb-4">Crear cuenta</h2>

                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label text-light"></label>
                        <input asp-for="Username" class="form-control bg-black text-light border-secondary" />
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label text-light"></label>
                        <input asp-for="Email" class="form-control bg-black text-light border-secondary" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label text-light"></label>
                        <input asp-for="Password" class="form-control bg-black text-light border-secondary" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label text-light"></label>
                        <input asp-for="ConfirmPassword" class="form-control bg-black text-light border-secondary" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-warning w-100">
                        Registrarme
                    </button>
                </form>

                <div class="mt-3 text-center">
                    <span class="text-secondary">�Ya tienes cuenta?</span>
                    <a asp-controller="Users" asp-action="Login" class="text-warning text-decoration-none ms-1">
                        Inicia sesi�n
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
