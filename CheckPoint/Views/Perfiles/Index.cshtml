@using CheckPoint.Models
@{
    ViewData["Title"] = "Perfil";
    var user = ViewBag.Usuario as Usuario;
    var profile = Model as Perfil;
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

@if (profile == null || user == null)
{
    <p class="text-secondary">Perfil no encontrado.</p>
    return;
}

<div class="cp-profile-banner" style="background-image:url('@profile.BannerUrl');"></div>

<div class="cp-profile-shell">
    <div class="d-flex align-items-center gap-3 flex-wrap cp-profile-header">
        <img src="@profile.AvatarUrl"
             class="cp-profile-avatar"
             alt="Avatar de @profile.DisplayName"
             onerror="this.src='/img/default-avatar.png'" />

        <div>
            <h3 class="text-warning mb-1">@profile.DisplayName</h3>
            <div class="text-secondary small d-flex align-items-center gap-2 flex-wrap">
                <span>@@user.Username</span>
                <span>-</span>
                <span>@user.Role</span>
                @if (!string.IsNullOrEmpty(profile.GamerTag))
                {
                    <span class="badge cp-badge-soft">@profile.GamerTag</span>
                }
            </div>
        </div>

        @if (currentUserId == user.Id)
        {
            <a asp-controller="Perfiles" asp-action="Edit" class="btn btn-sm btn-outline-warning ms-md-auto">Editar perfil</a>
        }
    </div>

    <div class="row g-3 mt-1">
        <div class="col-lg-8">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="mb-3">Resumen</h5>

                    @if (string.IsNullOrWhiteSpace(profile.Bio))
                    {
                        <p class="text-secondary mb-3">Este jugador aun no ha agregado biografia.</p>
                    }
                    else
                    {
                        <p class="text-secondary mb-3">@profile.Bio</p>
                    }

                    <h6 class="mb-2">Juegos favoritos</h6>
                    @if (profile.FavoriteGames != null && profile.FavoriteGames.Any())
                    {
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var g in profile.FavoriteGames)
                            {
                                <span class="badge cp-badge-soft">@g</span>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-secondary small mb-3">No hay juegos favoritos cargados.</p>
                    }

                    <h6 class="mt-4 mb-2">Redes</h6>
                    @if (profile.SocialLinks != null && profile.SocialLinks.Any())
                    {
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var link in profile.SocialLinks)
                            {
                                <a href="@link.Value" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-secondary">@link.Key</a>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-secondary small mb-0">No hay enlaces sociales registrados.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="mb-3">Estadisticas</h5>

                    <div class="cp-metric">
                        <strong>@profile.TotalEventsJoined</strong>
                        <span>Eventos jugados</span>
                    </div>
                    <div class="cp-metric">
                        <strong>@profile.TotalEventsOrganized</strong>
                        <span>Eventos organizados</span>
                    </div>
                    <div class="cp-metric mb-0">
                        <strong>@profile.ReputationScore</strong>
                        <span>Reputacion</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


