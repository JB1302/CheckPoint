@model CheckPoint.ViewModels.EditarPerfilViewModel
@{
    ViewData["Title"] = "Editar perfil";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <h3 class="text-warning mb-4">Editar perfil</h3>
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

            <div class="mb-3">
                <label asp-for="DisplayName" class="form-label text-light"></label>
                <input asp-for="DisplayName" class="form-control bg-dark text-light border-secondary" />
                <span asp-validation-for="DisplayName" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="GamerTag" class="form-label text-light"></label>
                <input asp-for="GamerTag" class="form-control bg-dark text-light border-secondary" />
            </div>
            <div class="mb-3">
                <label asp-for="Bio" class="form-label text-light"></label>
                <textarea asp-for="Bio" rows="3" class="form-control bg-dark text-light border-secondary"></textarea>
                <span asp-validation-for="Bio" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Country" class="form-label text-light"></label>
                <input asp-for="Country" class="form-control bg-dark text-light border-secondary" />
            </div>
            <div class="mb-3">
                <label asp-for="FavoriteGamesRaw" class="form-label text-light"></label>
                <input asp-for="FavoriteGamesRaw" class="form-control bg-dark text-light border-secondary" placeholder="League of Legends, Valorant" />
            </div>
            <hr class="border-secondary">
            <h6 class="text-warning">Redes sociales</h6>
            <div class="mb-3">
                <label asp-for="Twitch" class="form-label text-light"></label>
                <input asp-for="Twitch" class="form-control bg-dark text-light border-secondary" placeholder="https://twitch.tv/..." />
                <span asp-validation-for="Twitch" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="YouTube" class="form-label text-light"></label>
                <input asp-for="YouTube" class="form-control bg-dark text-light border-secondary" placeholder="https://youtube.com/..." />
                <span asp-validation-for="YouTube" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Twitter" class="form-label text-light"></label>
                <input asp-for="Twitter" class="form-control bg-dark text-light border-secondary" placeholder="https://twitter.com/..." />
                <span asp-validation-for="Twitter" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-warning px-5">Guardar</button>
                <a asp-action="Index" asp-route-userId="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


