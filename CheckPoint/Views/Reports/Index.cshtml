@using CheckPoint.Models.Reports
@model List<Report>

@{
    ViewData["Title"] = "Reportes";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <span class="cp-kicker">Moderación</span>
        <h2 class="text-warning mb-1">Reportes</h2>
        <p class="text-secondary mb-0">Gestiona los reportes enviados por los usuarios.</p>
    </div>

    <a asp-controller="Reports" asp-action="Create" class="btn btn-warning">
        Crear reporte
    </a>
</div>

<div class="card bg-dark border-secondary shadow-sm">
    <div class="card-body">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5 text-secondary">
                No hay reportes registrados.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Reportante</th>
                            <th>Tipo objetivo</th>
                            <th>ID objetivo</th>
                            <th>Motivo</th>
                            <th>Estado</th>
                            <th>Fecha</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var report in Model)
                        {
                            <tr>
                                <td>@report.ReporterId</td>
                                <td>@report.TargetType</td>
                                <td>@report.TargetId</td>
                                <td>
                                    @(report.Reason.Length > 80
                                        ? report.Reason.Substring(0, 80) + "..."
                                        : report.Reason)
                                </td>
                                <td>
                                    <span class="badge bg-warning text-dark">@report.Status</span>
                                </td>
                                <td>@report.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end">
                                    <a asp-controller="Reports" asp-action="Details" asp-route-id="@report.Id" class="btn btn-sm btn-outline-warning">
                                        Ver
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>