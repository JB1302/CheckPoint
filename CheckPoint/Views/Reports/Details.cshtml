@model CheckPoint.Models.Reports.Report
@{
    ViewData["Title"] = "Reporte";
}

<div class="card bg-dark text-white border-secondary">
    <div class="card-header text-white">
        <h2 class="text-white">Reporte</h2>
    </div>
    <div class="card-body text-white">
        <dl class="row text-white">
            <dt class="col-sm-3 text-white">Tipo:</dt>
            <dd class="col-sm-9 text-white">@Model.TargetType</dd>
            
            <dt class="col-sm-3 text-white">Motivo:</dt>
            <dd class="col-sm-9 text-white">@Model.Reason</dd>
            
            <dt class="col-sm-3 text-white">Reportado por:</dt>
            <dd class="col-sm-9 text-white">@Model.ReporterId</dd>
            
            <dt class="col-sm-3 text-white">Contenido reportado ID:</dt>
            <dd class="col-sm-9 text-white">@Model.TargetId</dd>
            
            <dt class="col-sm-3 text-white">Fecha Reporte:</dt>
            <dd class="col-sm-9 text-white">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
            
            <dt class="col-sm-3 text-white">Estado:</dt>
            <dd class="col-sm-9 text-white">@await Html.PartialAsync("_ReportStatusBadge", Model.Status)</dd>
            
            @if (!string.IsNullOrEmpty(Model.ResolutionNotes))
            {
                <dt class="col-sm-3 text-white">Notas de Resolución:</dt>
                <dd class="col-sm-9 text-white">@Model.ResolutionNotes</dd>
            }
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Index" class="btn btn-secondary">Volver</a>

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar estado</a>
        }
    </div>
</div>